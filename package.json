{
	"name": "metacoin-node",
	"version": "2.4.0",
	"main": "mtcnode.js",
	"description": "MetaCoin Node",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "http://metacoin.network"
	},
	"author": "Inblock",
	"keywords": [
		"MetaCoin",
		"MTC"
	],
	"dependencies": {
		"bignumber.js": "^11.1.4",
		"crc": "^4.3.2",
		"express": "^4.18.0",
		"level-rocksdb": "^5.0.0",
		"superagent": "^10.2.2",
		"winston": "^2.4.7"
	},
	"eslintConfig": {
		"root": true,
		"env": {
			"node": true
		},
		"extends": [
			"eslint:recommended"
		],
		"parserOptions": {
			"ecmaVersion": 2015,
			"parser": "babel-eslint",
			"sourceType": "module"
		},
		"rules": {
			"no-unused-vars": [
				"warn",
				{
					"vars": "all"
				}
			]
		}
	},
	"engines": {
		"node": ">=16.0.0"
	}
}